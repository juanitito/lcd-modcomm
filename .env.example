# Postgres (Neon recommandé via Vercel Marketplace)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Auth bête et méchant : un mot de passe maître
AUTH_PASSWORD=change-me

# Secret pour signer le cookie de session (32+ caractères)
# Génère avec: openssl rand -base64 32
SESSION_SECRET=change-me-with-32-plus-random-chars

# Qonto API (à brancher plus tard)
# QONTO_LOGIN=
# QONTO_API_KEY=

# Vercel Blob (archivage PDF factures, 10 ans)
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway (extraction structurée des factures historiques)
AI_GATEWAY_API_KEY=
